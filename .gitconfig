[user]
    name = Alexander Garustovich
    email = yukigaru@gmail.com

# Work email for repos under ~/work/
[includeIf "gitdir:~/work/"]
    path = ~/.gitconfig-work

[pull]
    rebase = true

[alias]
    s = status
    sh = show
    d = diff
    ds = diff --staged
    l = log --graph -30 --pretty=format:\"%Cgreen%ad%Creset %C(bold blue)%h%Creset %s %C(bold blue)(%an)%Creset\" --date=format:\"%d %b\"
    b = branch --sort=-committerdate --format \"%(color:bold green)%(refname:short): %(color:reset)%(committerdate:relative), %(color:bold blue)%(objectname:short)%(color:reset): %(contents:subject) %(color:bold blue)%(committername)\"
    c = commit -m
    ch = checkout
    cl = clone
    f = fetch --all
    p = pull
    ps = push
    a = add
    au = add -u
    cp = cherry-pick
    rb = rebase
    r = reset
    sm = submodule
    st = stash
    sta = stash apply
    bl = blame

[diff]
    context = 9
    algorithm = histogram

[rerere]
    enabled = true

[merge]
    conflictstyle = zdiff3

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global

[submodule]
    recurse = true

[color]
    ui = true

[push]
    default = simple

[safe]
    directory = ~/.vim/bundle/coc.nvim
[init]
    defaultBranch = main
